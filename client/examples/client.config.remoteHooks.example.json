{
  "serverUrl": "http://localhost:3000",
  "hostname": "host_1",
  "authKey": "your-secret-key-here",
  "localStorageDir": "./downloads",
  "logFile": "./logs/client.log",
  "silentMode": false,
  "localHooks": {
    "onDownloadName": {
      "name": "myapp.zip",
      "extractTo": "C:\\Program Files\\MyApp"
    },
    "moves": {
      "byNames": {
        "config.json": "C:\\Users\\Admin\\AppData\\config.json",
        "data.db": "C:\\Data\\database\\data.db"
      }
    }
  },
  "remoteHooks": {
    "host_2": {
      "onDownloadName": {
        "deployment_package.zip": {
          "name": "deployment_package.zip",
          "extractTo": "C:\\Deployment"
        }
      },
      "moves": {
        "byNames": {
          "settings.json": "C:\\ProgramData\\MyApp\\settings.json"
        }
      }
    },
    "host_3": {
      "onDownloadName": {
        "update.zip": {
          "name": "update.zip",
          "extractTo": "C:\\Updates"
        }
      },
      "moves": {
        "byNames": {
          "update.exe": "C:\\Program Files\\App\\update.exe"
        }
      }
    }
  }
}
