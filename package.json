{
  "name": "file-receiver",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch index.ts",
    "start": "bun run index.ts",
    "client": "bun run client.ts",
    "build:client": "bun build client.ts --compile --outfile client --external jszip",
    "build:client:win": "bun build client.ts --compile --outfile client.exe --external jszip",
    "build:client:linux": "bun build client.ts --compile --target=bun-linux-x64 --outfile client --external jszip",
    "build:client:mac": "bun build client.ts --compile --target=bun-darwin-x64 --outfile client --external jszip"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.0.3",
    "bun-types": "^1.3.5"
  },
  "dependencies": {
    "@types/bun": "^1.3.5",
    "jszip": "^3.10.1",
    "readable-stream": "^4.7.0"
  },
  "module": "index.ts",
  "private": true,
  "peerDependencies": {
    "typescript": "^5"
  }
}
