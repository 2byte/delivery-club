{
  "name": "file-receiver",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch server/index.ts",
    "start": "bun run server/index.ts",
    "server:cli": "bun run server/deliverierCli.ts",
    "server:init": "bun run server/deliverierCli.ts init",
    "client": "bun run client/client.ts",
    "build:client": "bun build client/client.ts --outfile client/dist/client.ts --target=bun",
    "build:client:win": "bun build client/client.ts --compile --outfile client/dist/client.exe",
    "build:client:linux": "bun build client/client.ts --compile --target=bun-linux-x64 --outfile client/dist/client",
    "build:client:mac": "bun build client/client.ts --compile --target=bun-darwin-x64 --outfile client/dist/client"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.0.3",
    "bun-types": "^1.3.5"
  },
  "dependencies": {
    "@types/bun": "^1.3.5",
    "readable-stream": "^4.7.0"
  },
  "module": "server/index.ts",
  "private": true,
  "peerDependencies": {
    "typescript": "^5"
  },
  "prettier": {
    "tabWidth": 4
  }
}
